{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/api/config",  "destination": "/api/config.js" },
    { "source": "/api/health",  "destination": "/api/health.js" },
    { "source": "/api/send-wa", "destination": "/api/send-wa.js" },
    { "source": "/(.*)",        "destination": "/index.html" }
  ]
}
